# 复制为 config/.env 后填写。不要提交到 Git。
BILI_ENABLED=true
BILI_MODE=web
BILI_ROOM_ID=123456
# 建议填写登录账号的 SESSDATA，否则可能 UID=0、用户名打码，单用户冷却不可靠。
BILI_SESSDATA=

# local: 输出到 runtime/local_test.flv；rtmp: 推到 Bilibili。
OUTPUT_MODE=local
LOCAL_OUTPUT=runtime/local_test.flv

# Bilibili 直播推流地址和推流码。不要把真实值发给别人。
RTMP_URL=rtmp://example.com/live-bvc
RTMP_STREAM_KEY=replace_with_real_stream_key

OUTPUT_WIDTH=1280
OUTPUT_HEIGHT=720
OUTPUT_FPS=30
VIDEO_BITRATE=3500k
VIDEO_MAXRATE=4000k
VIDEO_BUFSIZE=8000k
AUDIO_BITRATE=160k
X264_PRESET=superfast
CHUNK_SECONDS=20

HEALTH_BIND=127.0.0.1
HEALTH_PORT=8787

# 点歌限制：同一用户一分钟内只支持一次点歌。
USER_COOLDOWN_SECONDS=60
# 转场拉开阶段开始时间；下一首只会在该时间之后进入转场底层。
TRANSITION_REVEAL_AT=1.60
TRANSITION_SECONDS=2.15
