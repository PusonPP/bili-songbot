# Required before start-once/daemon. Optional for API-only check if BILI_ROOM_ID is set.
BILI_ROOM_ID=
BILI_LIVE_CENTER_URL=https://link.bilibili.com/p/center/index?spm_id_from=333.1387.0.0#/my-room/start-live
BILIUP_COOKIE_FILE=

# Timing and safety controls.
CHECK_INTERVAL_SECONDS=30
STOP_CONFIRM_TIMES=2
START_COOLDOWN_SECONDS=300
MAX_START_ATTEMPTS_PER_HOUR=3

# Browser and operation mode.
HEADLESS=true
DRY_RUN=false
LIVE_AREA_PARENT=电台
LIVE_AREA_CHILD=聊天电台
CHROMIUM_EXECUTABLE=
NAVIGATION_TIMEOUT_MS=60000
ACTION_TIMEOUT_MS=15000

# Runtime outputs and hooks.
RUNTIME_STREAM_ENV=/opt/bili-live-keeper/runtime/stream.env
ON_STARTED_HOOK=
SAVE_FAILURE_SCREENSHOT=false

# Optional built-in FFmpeg keepalive pusher. Enable this when no external OBS/FFmpeg
# service is already pushing to the runtime stream URL.
PUSH_KEEPALIVE_ENABLED=false
PUSH_KEEPALIVE_FFMPEG=/usr/bin/ffmpeg
PUSH_KEEPALIVE_VIDEO_SIZE=1280x720
PUSH_KEEPALIVE_FPS=15
PUSH_KEEPALIVE_VIDEO_BITRATE=800k
PUSH_KEEPALIVE_AUDIO_BITRATE=96k

# Local state/log paths for systemd deployment.
STATE_DIR=/var/lib/bili-live-keeper
LOG_DIR=/var/log/bili-live-keeper
LOG_LEVEL=INFO
